<div class="card">
  <%= link_to "戻る", training_sessions_path, class: "back-link" %>
  <h1 class="page-title">記録詳細</h1>
  <p class="page-subtitle">
    <%= l(@training_session.trained_on, format: :long) %>・<%= @training_session.exercise.name %>
  </p>

  <% if @training_session.memo.present? %>
    <div class="form-group">
      <label class="form-label">メモ</label>
      <p class="detail-text"><%= @training_session.memo %></p>
    </div>
  <% end %>

  <% if @training_session.machine&.setting_memo.present? %>
    <div class="machine-memo">
      <span class="machine-memo__icon">⚠</span>
      マシン設定メモ<br>
      <span class="machine-memo__text"><%= @training_session.machine.setting_memo %></span>
    </div>
  <% end %>

  <h2 class="section-title">記録</h2>
  <div class="sets-list">
    <% @training_session.training_sets.order(:set_number).each do |set| %>
      <div class="sets-list__row">
        <span class="sets-list__label">セット<%= set.set_number %></span>
        <span class="sets-list__value"><%= set.weight %>kg × <%= set.reps %>回</span>
      </div>
    <% end %>
  </div>
</div>
