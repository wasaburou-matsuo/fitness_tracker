<h1>トレーニングを記録</h1>

<%= form_with model: @training_session do |f| %>
  <% if @training_session.errors.any? %>
    <ul>
      <% @training_session.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  <% end %>

  <div>
    <%= f.label :trained_on, "日付" %>
    <%= f.date_field :trained_on %>
  </div>

  <div>
    <%= f.label :exercise_id, "種目" %>
    <%= f.select :exercise_id,
          @exercises.map { |e| [e.name, e.id] },
          { include_blank: "選択してください" } %>
  </div>

  <div>
    <%= f.label :machine_id, "マシン（任意）" %>
    <%= f.select :machine_id,
          @machines.map { |m| [m.name, m.id] },
          { include_blank: "なし（自重など）" } %>
  </div>

  <div>
    <%= f.label :memo, "メモ（任意）" %>
    <%= f.text_area :memo %>
  </div>

  <h2>セット</h2>
  <div data-controller="training-set">
    <div data-training-set-target="container">
      <%= f.fields_for :training_sets do |set_f| %>
        <div class="set-row">
          <span>セット<%= set_f.object.set_number %></span>
          <%= set_f.hidden_field :set_number, data: { set_number: true } %>
          <%= set_f.number_field :weight, step: 0.5, min: 0, placeholder: "重量 (kg)" %>
          <%= set_f.number_field :reps, min: 1, placeholder: "回数" %>
          <button type="button" data-action="click->training-set#removeSet">削除</button>
        </div>
      <% end %>
    </div>
    <button type="button" data-action="click->training-set#addSet">+ セットを追加</button>
  </div>

  <%= f.submit "記録する" %>
<% end %>

<%= link_to "戻る", root_path %>
