<div class="card">
  <%= link_to "戻る", gym_machines_path(@gym), class: "back-link" %>
  <h1 class="page-title">マシンを登録</h1>
  <p class="page-subtitle"><%= @gym.name %></p>

  <%= form_with model: [@gym, @machine] do |f| %>
    <% if @machine.errors.any? %>
      <div class="flash flash--alert">
        <ul class="error-list">
          <% @machine.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="form-group">
      <%= f.label :name, "マシン名" %>
      <%= f.text_field :name, placeholder: "例：スミスマシン" %>
    </div>

    <div class="form-group">
      <%= f.label :setting_memo, "マシン設定メモ" %>
      <%= f.text_area :setting_memo, placeholder: "例：座席3段目、安全バーは下から2段目" %>
    </div>

    <div class="form-actions">
      <%= f.submit "登録する", class: "btn-primary" %>
    </div>
  <% end %>
</div>
