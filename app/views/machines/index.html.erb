<div class="card">
  <%= link_to "戻る", exercises_path, class: "back-link" %>
  <h1 class="page-title">マシンを選択</h1>
  <p class="page-subtitle"><%= @gym.name %></p>

  <% if @machines.any? %>
    <div class="select-list">
      <% @machines.each do |machine| %>
        <%= link_to select_gym_machine_path(@gym, machine), class: "select-list__item" do %>
          <span><%= machine.name %></span>
          <span class="select-list__arrow">›</span>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <p class="empty-message">マシンが登録されていません。</p>
  <% end %>

  <div class="machine-actions">
    <%= link_to new_gym_machine_path(@gym), class: "btn-add" do %>
      + マシンを追加
    <% end %>
    <%= link_to "マシンなしで進む →", skip_gym_machines_path(@gym), class: "btn-skip" %>
  </div>
</div>
